# ================================
# DATABASE CONFIGURATION
# ================================
# PostgreSQL connection for Prisma (Supabase pooled connection recommended for production)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&uselibpqcompat=true&sslmode=require"

# Direct DB URL for migrations (Supabase direct connection)
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?uselibpqcompat=true&sslmode=require"

# ================================
# SECURITY
# ================================
# Secret for scheduled ingestion endpoint authorization (min 32 characters, strong random)
INGESTION_CRON_SECRET="replace-with-strong-random-secret-min-32-chars"

# ================================
# INGESTION CONFIGURATION
# ================================
# Data source: blockscout or rpc
BURN_SOURCE="blockscout"

# Chiliz explorer API base URL (supports .../api suffix or root URL)
CHILIZ_BLOCKSCOUT_API_URL="https://scan-api.chiliz.com/api"
CHILIZ_BLOCKSCOUT_API_KEY=""

# Blockscout action: txlist (native tx) or tokentx (token transfers)
BURN_BLOCKSCOUT_ACTION="txlist"

# Optional token contract filter when using tokentx
CHZ_TOKEN_CONTRACT=""

# Chiliz RPC URL for fallback or direct block scanning
CHILIZ_RPC_URL=""

# ================================
# THIRD-PARTY APIs
# ================================
# CoinGecko base URL (override only for proxies/mirrors)
COINGECKO_BASE_URL="https://api.coingecko.com/api/v3"

# ================================
# RUNTIME CONTROLS
# ================================
# Start date for historical burn data ingestion
BURN_DATA_START_DATE="2026-03-01T00:00:00.000Z"

# ================================
# APPLICATION ENVIRONMENT
# ================================
# Node environment
NODE_ENV="development"

# Public site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
BURN_BATCH_SIZE="100"
BURN_MAX_PAGES_PER_RUN="5"
BURN_RATE_LIMIT_DELAY_MS="800"
BURN_RPC_BATCH_BLOCKS="150"
BURN_RPC_LOOKBACK_BLOCKS="1500"
BURN_VERBOSE="true"

# Cron schedule (every 10 minutes by default)
BURN_CRON_SCHEDULE="*/10 * * * *"

# Optional app settings
NEXT_PUBLIC_APP_NAME="ChilizBurn"
NEXT_PUBLIC_CHAIN_NAME="Chiliz Chain"
